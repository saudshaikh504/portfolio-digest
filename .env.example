# ── Gemini API (FREE) ──────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, 15 requests/min — more than enough
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gmail App Password ─────────────────────────────────────────────────────────
# REQUIRED — do NOT use your regular Gmail password.
# Steps to generate:
#   1. Go to myaccount.google.com → Security
#   2. Enable "2-Step Verification" if not already on
#   3. Search "App passwords" in the Security page
#   4. Create one → App: Mail, Device: Windows Computer
#   5. Copy the 16-character password (no spaces) and paste below
GMAIL_APP_PASSWORD=your_16_char_app_password_here
